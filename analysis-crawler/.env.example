# Copy this file to `.env` and fill in your credentials.
# The .env file is git-ignored and never leaves your machine.

BASE_URL=https://safeeduman.com
LOGIN_EMAIL=your-email@example.com
LOGIN_PASSWORD=your-password

# ---- Optional tuning (defaults are sensible; leave blank to use them) ----

# Where captured artifacts are written (relative to this folder or absolute).
OUTPUT_DIR=./crawl-output

# Show the browser window while crawling (true) or run hidden (false).
HEADLESS=false

# Safety cap on number of distinct pages to visit.
MAX_PAGES=250

# Milliseconds to pause between page visits (be polite to the server).
CRAWL_DELAY_MS=600

# Comma-separated extra URL substrings to NEVER visit (in addition to built-in
# safe defaults like logout/delete). Example: /impersonate,/download
EXTRA_SKIP=

# If the login form uses non-standard fields, override the CSS selectors here.
# Leave blank to auto-detect standard email/password/submit inputs.
SEL_EMAIL=
SEL_PASSWORD=
SEL_SUBMIT=
