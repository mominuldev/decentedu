# Staging — prod-like, seeded. Copy to .env on the staging host and fill in the blanks;
# never commit the real file. See docs/09-testing-and-deployment.md Part B.

APP_NAME="DecentEdu"
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://staging.decentedu.example

# Structured JSON to stderr for the container platform's log aggregator to pick up.
LOG_CHANNEL=stderr
LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=decentedu
DB_USERNAME=decentedu
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@decentedu.example"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=staging.decentedu.example
FRONTEND_URL=https://staging.decentedu.example

SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_DSN=

VITE_APP_NAME="${APP_NAME}"
